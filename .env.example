# ============================================================
# .env.example — agw-cloud-api
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
# ============================================================

# ── Static API Token (shared with Fog Node / Raspberry Pi) ─
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# ── Database — Supabase Transaction Pooler (port 6543) ─────
# Format: postgresql://USER:PASSWORD@HOST:6543/DBNAME
DATABASE_URL=

# ══════════════════════════════════════════════════════════
# Variables used by the main app/main.py (Docker / local)
# ══════════════════════════════════════════════════════════

# Application
APP_NAME=AGW Cloud API
APP_VERSION=2.0.0
DEBUG=false

# JWT (used by main FastAPI app, not the Vercel serverless)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase JS SDK (optional — used by frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Edge Gateway long-lived token (used by main app auth)
EDGE_GATEWAY_TOKEN=

# Autenticación JWT y SMTP para Passwordless
SMTP_SERVER=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

JWT_SECRET=
JWT_ALGORITHM=HS256

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=["https://dashboard.vitalcrop.io","http://localhost:3000"]
